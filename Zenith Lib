    local function Restore()
        if not W._minimized or W._destroyed then return end
        W._minimized      = false
        Main.Size         = UDim2.new(0, 690, 0, 0)
        Main.Visible      = true
        Shadow.Visible    = true
        ReopenBtn.Visible = false
        Tween(Main,   TI.Spring, { Size = UDim2.new(0, 690, 0, 490) })
        Tween(Shadow, TI.Spring, { Size = UDim2.new(0, 710, 0, 510) })
    end

