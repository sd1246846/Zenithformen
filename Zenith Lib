--[[
    STEEL UI LIBRARY
    A premium, masculine, minimal UI framework for Roblox.
    Developed from scratch.
]]

local UIS = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()

local Library = {
    WindowCount = 0,
    Enabled = true,
    Toggled = true,
    Keybind = Enum.KeyCode.RightControl,
    Accent = Color3.fromRGB(50, 70, 90), -- Muted Steel Blue
    Black = Color3.fromRGB(15, 15, 15),
    Charcoal = Color3.fromRGB(25, 25, 25),
    Gray = Color3.fromRGB(40, 40, 40),
    Text = Color3.fromRGB(230, 230, 230),
    TextDark = Color3.fromRGB(150, 150, 150)
}

-- Cleanup existing UI
if CoreGui:FindFirstChild("SteelUI") then
    CoreGui:FindFirstChild("SteelUI"):Destroy()
end

local function Tween(obj, time, prop)
    TweenService:Create(obj, TweenInfo.new(time, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), prop):Play()
end

function Library:CreateWindow(title)
    local SteelUI = Instance.new("ScreenGui")
    SteelUI.Name = "SteelUI"
    SteelUI.ResetOnSpawn = false
    SteelUI.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    SteelUI.Parent = CoreGui

    local Main = Instance.new("Frame")
    local MainCorner = Instance.new("UICorner")
    local MainStroke = Instance.new("UIStroke")
    local TopBar = Instance.new("Frame")
    local Title = Instance.new("TextLabel")
    local Buttons = Instance.new("Frame")
    local Minimize = Instance.new("TextButton")
    local Close = Instance.new("TextButton")
    local Sidebar = Instance.new("Frame")
    local Container = Instance.new("Frame")
    local TabList = Instance.new("ScrollingFrame")
    local TabListLayout = Instance.new("UIListLayout")

    -- Reopen Button
    local Reopen = Instance.new("TextButton")
    local ReopenCorner = Instance.new("UICorner")
    local ReopenStroke = Instance.new("UIStroke")
    
    Reopen.Name = "Reopen"
    Reopen.Size = UDim2.new(0, 40, 0, 40)
    Reopen.Position = UDim2.new(0, 20, 1, -60)
    Reopen.BackgroundColor3 = Library.Charcoal
    Reopen.Text = "S"
    Reopen.TextColor3 = Library.Text
    Reopen.Font = Enum.Font.GothamBold
    Reopen.TextSize = 18
    Reopen.Visible = false
    Reopen.Parent = SteelUI
    
    ReopenCorner.CornerRadius = UDim.new(0, 8)
    ReopenCorner.Parent = Reopen
    ReopenStroke.Color = Library.Gray
    ReopenStroke.Thickness = 1
    ReopenStroke.Parent = Reopen

    -- Main Window Setup
    Main.Name = "Main"
    Main.Size = UDim2.new(0, 550, 0, 380)
    Main.Position = UDim2.new(0.5, -275, 0.5, -190)
    Main.BackgroundColor3 = Library.Black
    Main.BorderSizePixel = 0
    Main.ClipsDescendants = true
    Main.Parent = SteelUI

    MainCorner.CornerRadius = UDim.new(0, 6)
    MainCorner.Parent = Main
    MainStroke.Color = Library.Gray
    MainStroke.Thickness = 1
    MainStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    MainStroke.Parent = Main

    TopBar.Name = "TopBar"
    TopBar.Size = UDim2.new(1, 0, 0, 35)
    TopBar.BackgroundColor3 = Library.Charcoal
    TopBar.BorderSizePixel = 0
    TopBar.Parent = Main

    Title.Name = "Title"
    Title.Size = UDim2.new(0, 200, 1, 0)
    Title.Position = UDim2.new(0, 12, 0, 0)
    Title.BackgroundTransparency = 1
    Title.Text = title:upper()
    Title.TextColor3 = Library.Text
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 13
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.Parent = TopBar

    Buttons.Name = "Buttons"
    Buttons.Size = UDim2.new(0, 80, 1, 0)
    Buttons.Position = UDim2.new(1, -80, 0, 0)
    Buttons.BackgroundTransparency = 1
    Buttons.Parent = TopBar

    Close.Name = "Close"
    Close.Size = UDim2.new(0, 35, 0, 35)
    Close.Position = UDim2.new(1, -35, 0, 0)
    Close.BackgroundTransparency = 1
    Close.Text = "×"
    Close.TextColor3 = Library.TextDark
    Close.Font = Enum.Font.Gotham
    Close.TextSize = 20
    Close.Parent = Buttons

    Minimize.Name = "Minimize"
    Minimize.Size = UDim2.new(0, 35, 0, 35)
    Minimize.Position = UDim2.new(1, -70, 0, 0)
    Minimize.BackgroundTransparency = 1
    Minimize.Text = "-"
    Minimize.TextColor3 = Library.TextDark
    Minimize.Font = Enum.Font.Gotham
    Minimize.TextSize = 20
    Minimize.Parent = Buttons

    Sidebar.Name = "Sidebar"
    Sidebar.Size = UDim2.new(0, 140, 1, -35)
    Sidebar.Position = UDim2.new(0, 0, 0, 35)
    Sidebar.BackgroundColor3 = Library.Charcoal
    Sidebar.BorderSizePixel = 0
    Sidebar.Parent = Main

    TabList.Name = "TabList"
    TabList.Size = UDim2.new(1, 0, 1, 0)
    TabList.BackgroundTransparency = 1
    TabList.ScrollBarThickness = 0
    TabList.Parent = Sidebar

    TabListLayout.Parent = TabList
    TabListLayout.Padding = UDim.new(0, 2)
    TabListLayout.SortOrder = Enum.SortOrder.LayoutOrder

    Container.Name = "Container"
    Container.Size = UDim2.new(1, -150, 1, -45)
    Container.Position = UDim2.new(0, 145, 0, 40)
    Container.BackgroundTransparency = 1
    Container.Parent = Main

    -- Modal System
    local ModalOverlay = Instance.new("TextButton")
    ModalOverlay.Size = UDim2.new(1, 0, 1, 0)
    ModalOverlay.BackgroundColor3 = Color3.new(0,0,0)
    ModalOverlay.BackgroundTransparency = 1
    ModalOverlay.AutoButtonColor = false
    ModalOverlay.Text = ""
    ModalOverlay.Visible = false
    ModalOverlay.ZIndex = 100
    ModalOverlay.Parent = Main

    local Modal = Instance.new("Frame")
    Modal.Size = UDim2.new(0, 260, 0, 130)
    Modal.Position = UDim2.new(0.5, -130, 0.5, -65)
    Modal.BackgroundColor3 = Library.Charcoal
    Modal.Parent = ModalOverlay
    
    Instance.new("UICorner", Modal).CornerRadius = UDim.new(0, 6)
    local ms = Instance.new("UIStroke", Modal)
    ms.Color = Library.Gray
    ms.Thickness = 1

    local ModalText = Instance.new("TextLabel")
    ModalText.Size = UDim2.new(1, 0, 0, 60)
    ModalText.BackgroundTransparency = 1
    ModalText.Text = "Are you sure you want to close?"
    ModalText.TextColor3 = Library.Text
    ModalText.Font = Enum.Font.Gotham
    ModalText.TextSize = 14
    ModalText.Parent = Modal

    local ConfirmBtn = Instance.new("TextButton")
    ConfirmBtn.Size = UDim2.new(0, 100, 0, 35)
    ConfirmBtn.Position = UDim2.new(0.5, 5, 1, -45)
    ConfirmBtn.BackgroundColor3 = Color3.fromRGB(60, 20, 20)
    ConfirmBtn.Text = "Confirm"
    ConfirmBtn.TextColor3 = Library.Text
    ConfirmBtn.Font = Enum.Font.GothamBold
    ConfirmBtn.TextSize = 13
    ConfirmBtn.Parent = Modal
    Instance.new("UICorner", ConfirmBtn).CornerRadius = UDim.new(0, 4)

    local CancelBtn = Instance.new("TextButton")
    CancelBtn.Size = UDim2.new(0, 100, 0, 35)
    CancelBtn.Position = UDim2.new(0.5, -105, 1, -45)
    CancelBtn.BackgroundColor3 = Library.Gray
    CancelBtn.Text = "Cancel"
    CancelBtn.TextColor3 = Library.Text
    CancelBtn.Font = Enum.Font.GothamBold
    CancelBtn.TextSize = 13
    CancelBtn.Parent = Modal
    Instance.new("UICorner", CancelBtn).CornerRadius = UDim.new(0, 4)

    -- Functionality: Dragging
    local dragging, dragInput, dragStart, startPos
    TopBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = Main.Position
        end
    end)
    TopBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- Functionality: Minimize/Restore
    local function ToggleUI(state)
        Library.Toggled = state
        if state then
            Main.Visible = true
            Reopen.Visible = false
            Tween(Main, 0.3, {Size = UDim2.new(0, 550, 0, 380)})
        else
            Tween(Main, 0.2, {Size = UDim2.new(0, 550, 0, 0)})
            task.wait(0.2)
            Main.Visible = false
            Reopen.Visible = true
        end
    end

    Minimize.MouseButton1Click:Connect(function() ToggleUI(false) end)
    Reopen.MouseButton1Click:Connect(function() ToggleUI(true) end)

    -- Functionality: Close
    Close.MouseButton1Click:Connect(function()
        ModalOverlay.Visible = true
        Tween(ModalOverlay, 0.3, {BackgroundTransparency = 0.5})
    end)

    CancelBtn.MouseButton1Click:Connect(function()
        Tween(ModalOverlay, 0.2, {BackgroundTransparency = 1})
        task.wait(0.2)
        ModalOverlay.Visible = false
    end)

    ConfirmBtn.MouseButton1Click:Connect(function()
        SteelUI:Destroy()
    end)

    UIS.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == Library.Keybind then
            ToggleUI(not Library.Toggled)
        end
    end)

    local Window = {
        Tabs = {},
        CurrentTab = nil
    }

    function Window:AddTab(name)
        local TabBtn = Instance.new("TextButton")
        local TabFrame = Instance.new("ScrollingFrame")
        local TabFrameLayout = Instance.new("UIListLayout")

        TabBtn.Name = name.."Tab"
        TabBtn.Size = UDim2.new(1, 0, 0, 35)
        TabBtn.BackgroundTransparency = 1
        TabBtn.Text = name
        TabBtn.TextColor3 = Library.TextDark
        TabBtn.Font = Enum.Font.Gotham
        TabBtn.TextSize = 13
        TabBtn.Parent = TabList

        TabFrame.Name = name.."Frame"
        TabFrame.Size = UDim2.new(1, 0, 1, 0)
        TabFrame.BackgroundTransparency = 1
        TabFrame.Visible = false
        TabFrame.ScrollBarThickness = 2
        TabFrame.ScrollBarImageColor3 = Library.Gray
        TabFrame.Parent = Container

        TabFrameLayout.Parent = TabFrame
        TabFrameLayout.Padding = UDim.new(0, 8)
        TabFrameLayout.SortOrder = Enum.SortOrder.LayoutOrder

        if not Window.CurrentTab then
            Window.CurrentTab = TabFrame
            TabFrame.Visible = true
            TabBtn.TextColor3 = Library.Text
            TabBtn.Font = Enum.Font.GothamBold
        end

        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Container:GetChildren()) do v.Visible = false end
            for _, v in pairs(TabList:GetChildren()) do 
                if v:IsA("TextButton") then 
                    v.TextColor3 = Library.TextDark 
                    v.Font = Enum.Font.Gotham
                end 
            end
            TabFrame.Visible = true
            TabBtn.TextColor3 = Library.Text
            TabBtn.Font = Enum.Font.GothamBold
        end)

        local Tab = {}

        function Tab:AddSection(sname)
            local SectionFrame = Instance.new("Frame")
            local SectionLayout = Instance.new("UIListLayout")
            local SectionTitle = Instance.new("TextLabel")

            SectionFrame.Name = sname.."Section"
            SectionFrame.Size = UDim2.new(1, -10, 0, 30)
            SectionFrame.BackgroundTransparency = 1
            SectionFrame.Parent = TabFrame

            SectionTitle.Size = UDim2.new(1, 0, 0, 20)
            SectionTitle.BackgroundTransparency = 1
            SectionTitle.Text = sname:upper()
            SectionTitle.TextColor3 = Library.Accent
            SectionTitle.Font = Enum.Font.GothamBold
            SectionTitle.TextSize = 11
            SectionTitle.TextXAlignment = Enum.TextXAlignment.Left
            SectionTitle.Parent = SectionFrame

            SectionLayout.Parent = SectionFrame
            SectionLayout.Padding = UDim.new(0, 5)
            SectionLayout.SortOrder = Enum.SortOrder.LayoutOrder
            
            SectionLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                SectionFrame.Size = UDim2.new(1, -10, 0, SectionLayout.AbsoluteContentSize.Y)
                TabFrame.CanvasSize = UDim2.new(0,0,0, TabFrameLayout.AbsoluteContentSize.Y)
            end)

            local Section = {}

            function Section:AddToggle(text, default, callback)
                local Toggle = Instance.new("TextButton")
                local TTitle = Instance.new("TextLabel")
                local TBox = Instance.new("Frame")
                local TInner = Instance.new("Frame")
                
                Toggle.Size = UDim2.new(1, 0, 0, 30)
                Toggle.BackgroundColor3 = Library.Charcoal
                Toggle.AutoButtonColor = false
                Toggle.Text = ""
                Toggle.Parent = SectionFrame
                Instance.new("UICorner", Toggle).CornerRadius = UDim.new(0, 4)
                
                TTitle.Size = UDim2.new(1, -40, 1, 0)
                TTitle.Position = UDim2.new(0, 10, 0, 0)
                TTitle.BackgroundTransparency = 1
                TTitle.Text = text
                TTitle.TextColor3 = Library.Text
                TTitle.Font = Enum.Font.Gotham
                TTitle.TextSize = 13
                TTitle.TextXAlignment = Enum.TextXAlignment.Left
                TTitle.Parent = Toggle

                TBox.Size = UDim2.new(0, 34, 0, 18)
                TBox.Position = UDim2.new(1, -44, 0.5, -9)
                TBox.BackgroundColor3 = Library.Gray
                TBox.Parent = Toggle
                Instance.new("UICorner", TBox).CornerRadius = UDim.new(1, 0)

                TInner.Size = UDim2.new(0, 14, 0, 14)
                TInner.Position = default and UDim2.new(0, 18, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
                TInner.BackgroundColor3 = default and Library.Accent or Library.TextDark
                TInner.Parent = TBox
                Instance.new("UICorner", TInner).CornerRadius = UDim.new(1, 0)

                local state = default
                Toggle.MouseButton1Click:Connect(function()
                    state = not state
                    Tween(TInner, 0.2, {
                        Position = state and UDim2.new(0, 18, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
                        BackgroundColor3 = state and Library.Accent or Library.TextDark
                    })
                    callback(state)
                end)
            end

            function Section:AddButton(text, callback)
                local Button = Instance.new("TextButton")
                Button.Size = UDim2.new(1, 0, 0, 30)
                Button.BackgroundColor3 = Library.Charcoal
                Button.Text = text
                Button.TextColor3 = Library.Text
                Button.Font = Enum.Font.Gotham
                Button.TextSize = 13
                Button.Parent = SectionFrame
                Instance.new("UICorner", Button).CornerRadius = UDim.new(0, 4)

                Button.MouseButton1Down:Connect(function()
                    Tween(Button, 0.1, {BackgroundColor3 = Library.Gray})
                end)
                Button.MouseButton1Up:Connect(function()
                    Tween(Button, 0.1, {BackgroundColor3 = Library.Charcoal})
                    callback()
                end)
            end

            function Section:AddSlider(text, min, max, default, callback)
                local Slider = Instance.new("Frame")
                local STitle = Instance.new("TextLabel")
                local SVal = Instance.new("TextLabel")
                local SBar = Instance.new("TextButton")
                local SFill = Instance.new("Frame")

                Slider.Size = UDim2.new(1, 0, 0, 45)
                Slider.BackgroundTransparency = 1
                Slider.Parent = SectionFrame

                STitle.Size = UDim2.new(1, 0, 0, 20)
                STitle.BackgroundTransparency = 1
                STitle.Text = text
                STitle.TextColor3 = Library.Text
                STitle.Font = Enum.Font.Gotham
                STitle.TextSize = 13
                STitle.TextXAlignment = Enum.TextXAlignment.Left
                STitle.Parent = Slider

                SVal.Size = UDim2.new(1, 0, 0, 20)
                SVal.BackgroundTransparency = 1
                SVal.Text = tostring(default)
                SVal.TextColor3 = Library.TextDark
                SVal.Font = Enum.Font.Gotham
                SVal.TextSize = 12
                SVal.TextXAlignment = Enum.TextXAlignment.Right
                SVal.Parent = Slider

                SBar.Size = UDim2.new(1, 0, 0, 6)
                SBar.Position = UDim2.new(0, 0, 0, 28)
                SBar.BackgroundColor3 = Library.Charcoal
                SBar.AutoButtonColor = false
                SBar.Text = ""
                SBar.Parent = Slider
                Instance.new("UICorner", SBar)

                SFill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
                SFill.BackgroundColor3 = Library.Accent
                SFill.BorderSizePixel = 0
                SFill.Parent = SBar
                Instance.new("UICorner", SFill)

                local sliding = false
                local function move()
                    local mousePos = UIS:GetMouseLocation().X
                    local barPos = SBar.AbsolutePosition.X
                    local barSize = SBar.AbsoluteSize.X
                    local perc = math.clamp((mousePos - barPos) / barSize, 0, 1)
                    local val = math.floor(min + (max - min) * perc)
                    
                    SFill.Size = UDim2.new(perc, 0, 1, 0)
                    SVal.Text = tostring(val)
                    callback(val)
                end

                SBar.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = true
                        dragging = false -- Prevent UI move
                        move()
                    end
                end)
                UIS.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = false
                    end
                end)
                UIS.InputChanged:Connect(function(input)
                    if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
                        move()
                    end
                end)
            end

            function Section:AddDropdown(text, list, callback)
                local Dropdown = Instance.new("Frame")
                local DBtn = Instance.new("TextButton")
                local DTitle = Instance.new("TextLabel")
                local DVal = Instance.new("TextLabel")
                local DList = Instance.new("Frame")
                local DLay = Instance.new("UIListLayout")

                Dropdown.Size = UDim2.new(1, 0, 0, 30)
                Dropdown.BackgroundColor3 = Library.Charcoal
                Dropdown.ClipsDescendants = true
                Dropdown.Parent = SectionFrame
                Instance.new("UICorner", Dropdown).CornerRadius = UDim.new(0, 4)

                DBtn.Size = UDim2.new(1, 0, 0, 30)
                DBtn.BackgroundTransparency = 1
                DBtn.Text = ""
                DBtn.Parent = Dropdown

                DTitle.Size = UDim2.new(0, 100, 1, 0)
                DTitle.Position = UDim2.new(0, 10, 0, 0)
                DTitle.BackgroundTransparency = 1
                DTitle.Text = text
                DTitle.TextColor3 = Library.Text
                DTitle.Font = Enum.Font.Gotham
                DTitle.TextSize = 13
                DTitle.TextXAlignment = Enum.TextXAlignment.Left
                DTitle.Parent = Dropdown

                DVal.Size = UDim2.new(1, -20, 1, 0)
                DVal.BackgroundTransparency = 1
                DVal.Text = "..."
                DVal.TextColor3 = Library.TextDark
                DVal.Font = Enum.Font.Gotham
                DVal.TextSize = 12
                DVal.TextXAlignment = Enum.TextXAlignment.Right
                DVal.Parent = Dropdown

                DList.Size = UDim2.new(1, 0, 0, 0)
                DList.Position = UDim2.new(0, 0, 0, 30)
                DList.BackgroundTransparency = 1
                DList.Parent = Dropdown

                DLay.Parent = DList
                DLay.SortOrder = Enum.SortOrder.LayoutOrder

                local open = false
                DBtn.MouseButton1Click:Connect(function()
                    open = not open
                    local targetY = open and (30 + DLay.AbsoluteContentSize.Y) or 30
                    Tween(Dropdown, 0.2, {Size = UDim2.new(1, 0, 0, targetY)})
                end)

                for _, v in pairs(list) do
                    local Opt = Instance.new("TextButton")
                    Opt.Size = UDim2.new(1, 0, 0, 25)
                    Opt.BackgroundTransparency = 1
                    Opt.Text = v
                    Opt.TextColor3 = Library.TextDark
                    Opt.Font = Enum.Font.Gotham
                    Opt.TextSize = 12
                    Opt.Parent = DList

                    Opt.MouseButton1Click:Connect(function()
                        DVal.Text = v
                        open = false
                        Tween(Dropdown, 0.2, {Size = UDim2.new(1, 0, 0, 30)})
                        callback(v)
                    end)
                end
            end

            function Section:AddKeybind(text, default, callback)
                local Keybind = Instance.new("Frame")
                local KTitle = Instance.new("TextLabel")
                local KBtn = Instance.new("TextButton")

                Keybind.Size = UDim2.new(1, 0, 0, 30)
                Keybind.BackgroundColor3 = Library.Charcoal
                Keybind.Parent = SectionFrame
                Instance.new("UICorner", Keybind).CornerRadius = UDim.new(0, 4)

                KTitle.Size = UDim2.new(0, 100, 1, 0)
                KTitle.Position = UDim2.new(0, 10, 0, 0)
                KTitle.BackgroundTransparency = 1
                KTitle.Text = text
                KTitle.TextColor3 = Library.Text
                KTitle.Font = Enum.Font.Gotham
                KTitle.TextSize = 13
                KTitle.TextXAlignment = Enum.TextXAlignment.Left
                KTitle.Parent = Keybind

                KBtn.Size = UDim2.new(0, 60, 0, 20)
                KBtn.Position = UDim2.new(1, -70, 0.5, -10)
                KBtn.BackgroundColor3 = Library.Gray
                KBtn.Text = default.Name
                KBtn.TextColor3 = Library.Text
                KBtn.Font = Enum.Font.GothamBold
                KBtn.TextSize = 11
                KBtn.Parent = Keybind
                Instance.new("UICorner", KBtn).CornerRadius = UDim.new(0, 4)

                local current = default
                local binding = false

                KBtn.MouseButton1Click:Connect(function()
                    binding = true
                    KBtn.Text = "..."
                end)

                UIS.InputBegan:Connect(function(input)
                    if binding and input.UserInputType == Enum.UserInputType.Keyboard then
                        binding = false
                        current = input.KeyCode
                        KBtn.Text = current.Name
                    elseif not binding and input.KeyCode == current then
                        callback()
                    end
                end)
            end

            return Section
        end

        return Tab
    end

    return Window
end

return Library
