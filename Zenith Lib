--// Premium Masculine UI Library (From Scratch)
--// Built for exploit environments

if getgenv().PremiumUILoaded then
    pcall(function()
        getgenv().PremiumUI:Destroy()
    end)
end
getgenv().PremiumUILoaded = true

local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local mouse = player:GetMouse()

local Library = {}
Library.__index = Library

--// Theme
local Theme = {
    BG = Color3.fromRGB(18,18,18),
    Light = Color3.fromRGB(28,28,28),
    Accent = Color3.fromRGB(60,70,90),
    Stroke = Color3.fromRGB(50,50,50),
    Text = Color3.fromRGB(220,220,220)
}

--// Helper Tween
local function Tween(obj, props, t)
    TweenService:Create(obj, TweenInfo.new(t or 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

--// Create
function Library:CreateWindow(title)
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "PremiumUI"
    ScreenGui.Parent = game.CoreGui
    ScreenGui.ResetOnSpawn = false

    getgenv().PremiumUI = ScreenGui

    -- MAIN
    local Main = Instance.new("Frame", ScreenGui)
    Main.Size = UDim2.fromOffset(520, 380)
    Main.Position = UDim2.fromScale(0.5,0.5) - UDim2.fromOffset(260,190)
    Main.BackgroundColor3 = Theme.BG
    Main.BorderSizePixel = 0

    Instance.new("UICorner", Main).CornerRadius = UDim.new(0,6)
    local stroke = Instance.new("UIStroke", Main)
    stroke.Color = Theme.Stroke

    -- TOPBAR
    local Top = Instance.new("Frame", Main)
    Top.Size = UDim2.new(1,0,0,32)
    Top.BackgroundTransparency = 1

    local Title = Instance.new("TextLabel", Top)
    Title.Text = title
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 14
    Title.TextColor3 = Theme.Text
    Title.Position = UDim2.fromOffset(10,0)
    Title.Size = UDim2.fromOffset(200,32)
    Title.BackgroundTransparency = 1
    Title.TextXAlignment = Enum.TextXAlignment.Left

    -- BUTTONS
    local Min = Instance.new("TextButton", Top)
    Min.Text = "-"
    Min.Size = UDim2.fromOffset(30,30)
    Min.Position = UDim2.new(1,-70,0,1)
    Min.BackgroundColor3 = Theme.Light
    Min.TextColor3 = Theme.Text
    Instance.new("UICorner", Min)

    local Close = Min:Clone()
    Close.Text = "X"
    Close.Position = UDim2.new(1,-35,0,1)
    Close.Parent = Top

    -- DRAGGING
    local dragging, dragStart, startPos

    Top.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = Main.Position
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            Main.Position = startPos + UDim2.fromOffset(delta.X, delta.Y)
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    -- REOPEN BUTTON
    local Reopen = Instance.new("TextButton", ScreenGui)
    Reopen.Size = UDim2.fromOffset(120,30)
    Reopen.Position = UDim2.fromScale(0.5,0.9)
    Reopen.Text = "Reopen UI"
    Reopen.Visible = false
    Reopen.BackgroundColor3 = Theme.Light
    Reopen.TextColor3 = Theme.Text
    Instance.new("UICorner", Reopen)

    -- MODAL
    local Modal = Instance.new("Frame", ScreenGui)
    Modal.Size = UDim2.fromOffset(300,150)
    Modal.Position = UDim2.fromScale(0.5,0.5) - UDim2.fromOffset(150,75)
    Modal.BackgroundColor3 = Theme.BG
    Modal.Visible = false
    Instance.new("UICorner", Modal)
    Instance.new("UIStroke", Modal).Color = Theme.Stroke

    local MText = Instance.new("TextLabel", Modal)
    MText.Text = "Are you sure you want to close?"
    MText.Size = UDim2.new(1,-20,0,60)
    MText.Position = UDim2.fromOffset(10,10)
    MText.TextWrapped = true
    MText.BackgroundTransparency = 1
    MText.TextColor3 = Theme.Text
    MText.Font = Enum.Font.Gotham

    local Confirm = Instance.new("TextButton", Modal)
    Confirm.Text = "Confirm"
    Confirm.Size = UDim2.fromOffset(120,30)
    Confirm.Position = UDim2.fromOffset(20,100)
    Confirm.BackgroundColor3 = Theme.Accent
    Confirm.TextColor3 = Theme.Text
    Instance.new("UICorner", Confirm)

    local Cancel = Confirm:Clone()
    Cancel.Text = "Cancel"
    Cancel.Position = UDim2.fromOffset(160,100)
    Cancel.Parent = Modal

    -- MINIMIZE
    Min.MouseButton1Click:Connect(function()
        Main.Visible = false
        Reopen.Visible = true
    end)

    Reopen.MouseButton1Click:Connect(function()
        Main.Visible = true
        Reopen.Visible = false
    end)

    -- CLOSE
    Close.MouseButton1Click:Connect(function()
        Modal.Visible = true
        Modal.BackgroundTransparency = 1
        Tween(Modal, {BackgroundTransparency = 0}, 0.2)
    end)

    Cancel.MouseButton1Click:Connect(function()
        Modal.Visible = false
    end)

    Confirm.MouseButton1Click:Connect(function()
        ScreenGui:Destroy()
        getgenv().PremiumUILoaded = false
    end)

    -- KEYBIND (RightCtrl)
    UIS.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == Enum.KeyCode.RightControl then
            Main.Visible = not Main.Visible
            Reopen.Visible = not Main.Visible
        end
    end)

    -- TAB HOLDER
    local TabHolder = Instance.new("Frame", Main)
    TabHolder.Size = UDim2.new(0,120,1,-32)
    TabHolder.Position = UDim2.fromOffset(0,32)
    TabHolder.BackgroundColor3 = Theme.Light

    local Content = Instance.new("Frame", Main)
    Content.Size = UDim2.new(1,-120,1,-32)
    Content.Position = UDim2.fromOffset(120,32)
    Content.BackgroundTransparency = 1

    local Window = {}

    function Window:AddTab(name)
        local TabButton = Instance.new("TextButton", TabHolder)
        TabButton.Size = UDim2.new(1,0,0,30)
        TabButton.Text = name
        TabButton.BackgroundTransparency = 1
        TabButton.TextColor3 = Theme.Text

        local Page = Instance.new("Frame", Content)
        Page.Size = UDim2.new(1,0,1,0)
        Page.Visible = false
        Page.BackgroundTransparency = 1

        TabButton.MouseButton1Click:Connect(function()
            for _,v in pairs(Content:GetChildren()) do
                if v:IsA("Frame") then v.Visible = false end
            end
            Page.Visible = true
        end)

        local Tab = {}

        function Tab:AddSection(name)
            local Section = Instance.new("Frame", Page)
            Section.Size = UDim2.new(1,-10,0,200)
            Section.Position = UDim2.fromOffset(5,5)
            Section.BackgroundColor3 = Theme.Light
            Instance.new("UICorner", Section)

            local UIList = Instance.new("UIListLayout", Section)
            UIList.Padding = UDim.new(0,5)

            local Sec = {}

            function Sec:AddButton(text, callback)
                local Btn = Instance.new("TextButton", Section)
                Btn.Size = UDim2.new(1,-10,0,30)
                Btn.Text = text
                Btn.BackgroundColor3 = Theme.BG
                Btn.TextColor3 = Theme.Text

                Btn.MouseButton1Click:Connect(function()
                    Tween(Btn, {BackgroundColor3 = Theme.Accent}, 0.1)
                    task.wait(0.1)
                    Tween(Btn, {BackgroundColor3 = Theme.BG}, 0.1)
                    callback()
                end)
            end

            function Sec:AddToggle(text, default, callback)
                local val = default
                local Btn = Instance.new("TextButton", Section)
                Btn.Size = UDim2.new(1,-10,0,30)
                Btn.Text = text .. ": " .. tostring(val)
                Btn.BackgroundColor3 = Theme.BG
                Btn.TextColor3 = Theme.Text

                Btn.MouseButton1Click:Connect(function()
                    val = not val
                    Btn.Text = text .. ": " .. tostring(val)
                    callback(val)
                end)
            end

            function Sec:AddSlider(text, min, max, def, callback)
                local val = def

                local Frame = Instance.new("Frame", Section)
                Frame.Size = UDim2.new(1,-10,0,40)
                Frame.BackgroundTransparency = 1

                local Bar = Instance.new("Frame", Frame)
                Bar.Size = UDim2.new(1,0,0,6)
                Bar.Position = UDim2.fromOffset(0,20)
                Bar.BackgroundColor3 = Theme.BG

                local Fill = Instance.new("Frame", Bar)
                Fill.Size = UDim2.new((val-min)/(max-min),0,1,0)
                Fill.BackgroundColor3 = Theme.Accent

                local dragging = false

                Bar.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true
                    end
                end)

                UIS.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                    end
                end)

                UIS.InputChanged:Connect(function(i)
                    if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
                        local pct = math.clamp((i.Position.X - Bar.AbsolutePosition.X)/Bar.AbsoluteSize.X,0,1)
                        Fill.Size = UDim2.new(pct,0,1,0)
                        val = math.floor(min + (max-min)*pct)
                        callback(val)
                    end
                end)
            end

            return Sec
        end

        return Tab
    end

    return Window
end

return Library
