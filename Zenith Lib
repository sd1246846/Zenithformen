            -- ────────────────────────────────────
            -- TOGGLE
            -- ────────────────────────────────────
            function Sec:AddToggle(text, default, cb)
                cb = cb or function() end
                local state = default == true

                local Row = New("Frame", {
                    Size             = UDim2.new(1, 0, 0, 38),
                    BackgroundTransparency = 1,
                    BorderSizePixel  = 0,
                    LayoutOrder      = #Items:GetChildren(),
                    ZIndex           = 5,
                    Parent           = Items,
                })

                -- Full-row click zone (but only for toggle, not drag)
                local Click = New("TextButton", {
                    Size             = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text             = "",
                    BorderSizePixel  = 0,
                    AutoButtonColor  = false,
                    ZIndex           = 7,
                    Parent           = Row,
                })

                New("TextLabel", {
                    Size             = UDim2.new(1, -72, 1, 0),
                    Position         = UDim2.new(0, 14, 0, 0),
                    BackgroundTransparency = 1,
                    Text             = text,
                    TextColor3       = T.TextHi,
                    Font             = Enum.Font.GothamMedium,
                    TextSize         = 12,
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    ZIndex           = 6,
                    Parent           = Row,
                })

                -- Track background
                local Track = New("Frame", {
                    Size             = UDim2.new(0, 40, 0, 21),
                    Position         = UDim2.new(1, -52, 0.5, -10),
                    BackgroundColor3 = state and T.ToggleOn or T.ToggleOff,
                    BorderSizePixel  = 0,
                    ZIndex           = 6,
                    Parent           = Row,
                })
                Corner(Track, 12)
                Stroke(Track, T.Border, 1)

                -- Knob
                local Knob = New("Frame", {
                    Size             = UDim2.new(0, 15, 0, 15),
                    Position         = state
                        and UDim2.new(1, -18, 0.5, -7)
                        or  UDim2.new(0, 3,   0.5, -7),
                    BackgroundColor3 = Color3.fromRGB(215, 220, 238),
                    BorderSizePixel  = 0,
                    ZIndex           = 7,
                    Parent           = Track,
                })
                Corner(Knob, 10)

                local function SetState(v)
                    state = v
                    if state then
                        Tween(Track, TI.Med, { BackgroundColor3 = T.ToggleOn })
                        Tween(Knob,  TI.Med, { Position = UDim2.new(1, -18, 0.5, -7) })
                    else
                        Tween(Track, TI.Med, { BackgroundColor3 = T.ToggleOff })
                        Tween(Knob,  TI.Med, { Position = UDim2.new(0, 3, 0.5, -7) })
                    end
                    pcall(cb, state)
                end

                Click.MouseButton1Click:Connect(function() SetState(not state) end)
                Click.MouseEnter:Connect(function()
                    Tween(Row, TI.Fast, { BackgroundColor3 = Color3.fromRGB(0,0,0) })
                end)

                local Obj = {}
                function Obj:Set(v) SetState(v) end
                function Obj:Get() return state end
                return Obj
            end

            -- ────────────────────────────────────
            -- SLIDER
            -- ────────────────────────────────────
            function Sec:AddSlider(text, min, max, default, cb)
                cb      = cb      or function() end
                min     = min     or 0
                max     = max     or 100
                local val = math.clamp(default or min, min, max)

                local Row = New("Frame", {
                    Size             = UDim2.new(1, 0, 0, 52),
                    BackgroundTransparency = 1,
                    BorderSizePixel  = 0,
                    LayoutOrder      = #Items:GetChildren(),
                    ZIndex           = 5,
                    Parent           = Items,
                })

                -- Label row
                New("TextLabel", {
                    Size             = UDim2.new(1, -60, 0, 22),
                    Position         = UDim2.new(0, 14, 0, 5),
                    BackgroundTransparency = 1,
                    Text             = text,
                    TextColor3       = T.TextHi,
                    Font             = Enum.Font.GothamMedium,
                    TextSize         = 12,
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    ZIndex           = 6,
                    Parent           = Row,
                })

                local ValLbl = New("TextLabel", {
                    Size             = UDim2.new(0, 46, 0, 22),
                    Position         = UDim2.new(1, -58, 0, 5),
                    BackgroundTransparency = 1,
                    Text             = tostring(val),
                    TextColor3       = T.TextAccent,
                    Font             = Enum.Font.GothamBold,
                    TextSize         = 12,
                    TextXAlignment   = Enum.TextXAlignment.Right,
                    ZIndex           = 6,
                    Parent           = Row,
                })

                -- Track area (wider hit target)
                local TrackArea = New("Frame", {
                    Size             = UDim2.new(1, -28, 0, 18),
                    Position         = UDim2.new(0, 14, 0, 30),
                    BackgroundTransparency = 1,
                    BorderSizePixel  = 0,
                    ZIndex           = 6,
                    Parent           = Row,
                })

                local Track = New("Frame", {
                    Name             = "Track",
                    Size             = UDim2.new(1, 0, 0, 5),
                    Position         = UDim2.new(0, 0, 0.5, -2),
                    BackgroundColor3 = T.SliderTrack,
                    BorderSizePixel  = 0,
                    ZIndex           = 6,
                    Parent           = TrackArea,
                })
                Corner(Track, 4)

                local ratio  = (val - min) / (max - min)
                local Fill = New("Frame", {
                    Name             = "Fill",
                    Size             = UDim2.new(ratio, 0, 1, 0),
                    BackgroundColor3 = T.SliderFill,
                    BorderSizePixel  = 0,
                    ZIndex           = 7,
                    Parent           = Track,
                })
                Corner(Fill, 4)

                local Knob = New("Frame", {
                    Name             = "Knob",
                    Size             = UDim2.new(0, 14, 0, 14),
                    Position         = UDim2.new(ratio, -7, 0.5, -7),
                    BackgroundColor3 = T.SliderKnob,
                    BorderSizePixel  = 0,
                    ZIndex           = 8,
                    Parent           = Track,
                })
                Corner(Knob, 10)
                Stroke(Knob, T.Accent, 1.5)

                -- Sliding logic (CRITICAL: uses _sliding flag so window doesn't move)
                local _sliding = false

                local function ApplySlide(mouseX)
                    local ap  = Track.AbsolutePosition
                    local as  = Track.AbsoluteSize
                    local r   = math.clamp((mouseX - ap.X) / as.X, 0, 1)
                    val       = math.floor(min + (max - min) * r + 0.5)
                    ValLbl.Text = tostring(val)
                    Tween(Fill,  TI.Fast, { Size     = UDim2.new(r, 0, 1, 0) })
                    Tween(Knob,  TI.Fast, { Position = UDim2.new(r, -7, 0.5, -7) })
                    pcall(cb, val)
                end

                TrackArea.InputBegan:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        _sliding = true
                        _drag    = false  -- prevent window drag conflict
                        ApplySlide(inp.Position.X)
                    end
                end)
                Knob.InputBegan:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        _sliding = true
                        _drag    = false
                    end
                end)

                Track(UserInputService.InputChanged:Connect(function(inp)
                    if _sliding and inp.UserInputType == Enum.UserInputType.MouseMovement then
                        ApplySlide(inp.Position.X)
                    end
                end))
                Track(UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        _sliding = false
                    end
                end))

                local Obj = {}
                function Obj:Set(v)
                    v   = math.clamp(v, min, max)
                    val = v
                    local r = (v - min) / (max - min)
                    ValLbl.Text = tostring(v)
                    Tween(Fill,  TI.Med, { Size     = UDim2.new(r, 0, 1, 0) })
                    Tween(Knob,  TI.Med, { Position = UDim2.new(r, -7, 0.5, -7) })
                end
                function Obj:Get() return val end
                return Obj
            end

            -- ────────────────────────────────────
            -- DROPDOWN
            -- ────────────────────────────────────
            function Sec:AddDropdown(text, opts, cb)
                cb = cb or function() end
                local sel      = opts[1] or "None"
                local expanded = false
                local dropList = nil  -- live reference

                local Row = New("Frame", {
                    Size             = UDim2.new(1, 0, 0, 38),
                    BackgroundTransparency = 1,
                    BorderSizePixel  = 0,
                    ClipsDescendants = false,
                    LayoutOrder      = #Items:GetChildren(),
                    ZIndex           = 5,
                    Parent           = Items,
                })

                New("TextLabel", {
                    Size             = UDim2.new(0.5, 0, 1, 0),
                    Position         = UDim2.new(0, 14, 0, 0),
                    BackgroundTransparency = 1,
                    Text             = text,
                    TextColor3       = T.TextHi,
                    Font             = Enum.Font.GothamMedium,
                    TextSize         = 12,
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    ZIndex           = 6,
                    Parent           = Row,
                })

                local DropBtn = New("TextButton", {
                    Size             = UDim2.new(0, 138, 0, 26),
                    Position         = UDim2.new(1, -150, 0.5, -13),
                    BackgroundColor3 = T.Panel,
                    Text             = "",
                    BorderSizePixel  = 0,
                    AutoButtonColor  = false,
                    ZIndex           = 6,
                    Parent           = Row,
                })
                Corner(DropBtn, 5)
                Stroke(DropBtn, T.Border, 1)

                local SelLbl = New("TextLabel", {
                    Size             = UDim2.new(1, -22, 1, 0),
                    Position         = UDim2.new(0, 8, 0, 0),
                    BackgroundTransparency = 1,
                    Text             = sel,
                    TextColor3       = T.TextHi,
                    Font             = Enum.Font.Gotham,
                    TextSize         = 11,
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    ZIndex           = 7,
                    Parent           = DropBtn,
                })

                local Arrow = New("TextLabel", {
                    Size             = UDim2.new(0, 16, 1, 0),
                    Position         = UDim2.new(1, -18, 0, 0),
                    BackgroundTransparency = 1,
                    Text             = "▾",
                    TextColor3       = T.TextLow,
                    Font             = Enum.Font.GothamBold,
                    TextSize         = 11,
                    ZIndex           = 7,
                    Parent           = DropBtn,
                })

                DropBtn.MouseEnter:Connect(function()
                    Tween(DropBtn, TI.Fast, { BackgroundColor3 = T.Elevated })
                end)
                DropBtn.MouseLeave:Connect(function()
                    Tween(DropBtn, TI.Fast, { BackgroundColor3 = T.Panel })
                end)

                local function CloseDropdown()
                    expanded = false
                    Tween(Arrow, TI.Fast, { Rotation = 0 })
                    if dropList then
                        Tween(dropList, TI.Med, { Size = UDim2.new(0, 138, 0, 0),
                                                   BackgroundTransparency = 0.3 })
                        local ref = dropList
                        task.delay(0.23, function() pcall(function() ref:Destroy() end) end)
                        dropList = nil
                    end
                end

                DropBtn.MouseButton1Click:Connect(function()
                    if expanded then
                        CloseDropdown()
                        return
                    end
                    expanded = true
                    Tween(Arrow, TI.Fast, { Rotation = 180 })

                    -- Build floating list anchored to screen space
                    local btnAbs  = DropBtn.AbsolutePosition
                    local btnSize = DropBtn.AbsoluteSize
                    local listH   = #opts * 26 + 6

                    local DL = New("Frame", {
                        Name             = "DropList",
                        Size             = UDim2.new(0, 138, 0, 0),
                        Position         = UDim2.new(0, btnAbs.X, 0, btnAbs.Y + btnSize.Y + 3),
                        BackgroundColor3 = T.Panel,
                        BackgroundTransparency = 0.3,
                        BorderSizePixel  = 0,
                        ClipsDescendants = true,
                        ZIndex           = 500,
                        Parent           = Root,  -- in Root so it floats above everything
                    })
                    Corner(DL, 6)
                    Stroke(DL, T.BorderHi, 1)
                    ListLayout(DL, Enum.FillDirection.Vertical, 0)
                    Padding(DL, 3, 3, 0, 0)
                    dropList = DL

                    for i, opt in ipairs(opts) do
                        local isActive = (opt == sel)
                        local OBtn = New("TextButton", {
                            Name             = "Opt_" .. opt,
                            Size             = UDim2.new(1, 0, 0, 26),
                            BackgroundColor3 = isActive and T.AccentDim or T.Panel,
                            Text             = opt,
                            TextColor3       = isActive and T.TextHi or T.TextMid,
                            Font             = Enum.Font.GothamMedium,
                            TextSize         = 11,
                            BorderSizePixel  = 0,
                            AutoButtonColor  = false,
                            ZIndex           = 501,
                            LayoutOrder      = i,
                            Parent           = DL,
                        })
                        Padding(OBtn, 0, 0, 8, 4)
                        OBtn.MouseEnter:Connect(function()
                            Tween(OBtn, TI.Fast, { BackgroundColor3 = T.Elevated })
                        end)
                        OBtn.MouseLeave:Connect(function()
                            Tween(OBtn, TI.Fast, { BackgroundColor3 = isActive and T.AccentDim or T.Panel })
                        end)
                        OBtn.MouseButton1Click:Connect(function()
                            sel = opt
                            SelLbl.Text = opt
                            CloseDropdown()
                            pcall(cb, opt)
                        end)
                    end

                    Tween(DL, TI.Med, { Size = UDim2.new(0, 138, 0, listH),
                                        BackgroundTransparency = 0 })
                end)

                -- Close if clicked outside
                Track(UserInputService.InputBegan:Connect(function(inp)
                    if expanded and inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        -- Check if click was outside
                        task.wait()
                        if expanded then
                            local mp = UserInputService:GetMouseLocation()
                            if dropList then
                                local ap = dropList.AbsolutePosition
                                local as = dropList.AbsoluteSize
                                if mp.X < ap.X or mp.X > ap.X + as.X
                                or mp.Y < ap.Y or mp.Y > ap.Y + as.Y then
                                    CloseDropdown()
                                end
                            end
                        end
                    end
                end))

                local Obj = {}
                function Obj:Set(v)
                    for _, o in ipairs(opts) do
                        if o == v then sel = v; SelLbl.Text = v; pcall(cb, v); break end
                    end
                end
                function Obj:Get() return sel end
                return Obj
            end

            -- ────────────────────────────────────
            -- KEYBIND
            -- ────────────────────────────────────
            function Sec:AddKeybind(text, default, cb)
                cb = cb or function() end
                local key      = default or Enum.KeyCode.Unknown
                local listening = false

                local Row = New("Frame", {
                    Size             = UDim2.new(1, 0, 0, 38),
                    BackgroundTransparency = 1,
                    BorderSizePixel  = 0,
                    LayoutOrder      = #Items:GetChildren(),
                    ZIndex           = 5,
                    Parent           = Items,
                })

                New("TextLabel", {
                    Size             = UDim2.new(0.55, 0, 1, 0),
                    Position         = UDim2.new(0, 14, 0, 0),
                    BackgroundTransparency = 1,
                    Text             = text,
                    TextColor3       = T.TextHi,
                    Font             = Enum.Font.GothamMedium,
                    TextSize         = 12,
                    TextXAlignment   = Enum.TextXAlignment.Left,
                    ZIndex           = 6,
                    Parent           = Row,
                })

                local function KeyName(k)
                    if k == Enum.KeyCode.Unknown then return "None" end
                    return k.Name
                end

                local KeyBtn = New("TextButton", {
                    Size             = UDim2.new(0, 92, 0, 24),
                    Position         = UDim2.new(1, -104, 0.5, -12),
                    BackgroundColor3 = T.Panel,
                    Text             = KeyName(key),
                    TextColor3       = T.TextAccent,
                    Font             = Enum.Font.GothamSemibold,
                    TextSize         = 11,
                    BorderSizePixel  = 0,
                    AutoButtonColor  = false,
                    ZIndex           = 6,
                    Parent           = Row,
                })
                Corner(KeyBtn, 5)
                Stroke(KeyBtn, T.Border, 1)

                KeyBtn.MouseEnter:Connect(function()
                    if not listening then Tween(KeyBtn, TI.Fast, { BackgroundColor3 = T.Elevated }) end
                end)
                KeyBtn.MouseLeave:Connect(function()
                    if not listening then Tween(KeyBtn, TI.Fast, { BackgroundColor3 = T.Panel }) end
                end)

                KeyBtn.MouseButton1Click:Connect(function()
                    if listening then return end
                    listening       = true
                    KeyBtn.Text     = "[ ... ]"
                    KeyBtn.TextColor3 = T.TextMid
                    Tween(KeyBtn, TI.Fast, { BackgroundColor3 = T.AccentDim })
                end)

                Track(UserInputService.InputBegan:Connect(function(inp, proc)
                    if listening then
                        -- Accept any keyboard key
                        if inp.UserInputType == Enum.UserInputType.Keyboard then
                            key             = inp.KeyCode
                            KeyBtn.Text     = KeyName(key)
                            KeyBtn.TextColor3 = T.TextAccent
                            Tween(KeyBtn, TI.Fast, { BackgroundColor3 = T.Panel })
                            listening       = false
                        end
                        return  -- consume input while listening
                    end
                    if not proc
                    and inp.UserInputType == Enum.UserInputType.Keyboard
                    and inp.KeyCode == key
                    and key ~= Enum.KeyCode.Unknown then
                        pcall(cb)
                    end
                end))

                local Obj = {}
                function Obj:Set(k) key = k; KeyBtn.Text = KeyName(k) end
                function Obj:Get() return key end
                return Obj
            end

            return Sec
        end -- AddSection

        return Tab
    end -- AddTab

    -- ── Public window API ──────────────────────
    function W:SetKey(keyCode)
        W._toggleKey = keyCode
    end

    function W:Destroy()
        if not W._destroyed then
            ShowCloseModal()
        end
    end

    return W
end -- CreateWindow

return IronUI
