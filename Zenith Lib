    function W:AddTab(tabName)
        local Tab      = {}
        Tab._sections  = {}
        Tab._name      = tabName
        Tab._active    = false

        -- ── Sidebar button ──────────────────
        local TBtn = New("TextButton", {
            Name             = "Tab_" .. tabName,
            Size             = UDim2.new(1, 0, 0, 34),
            BackgroundColor3 = T.Surface,
            Text             = "",
            BorderSizePixel  = 0,
            AutoButtonColor  = false,
            ZIndex           = 4,
            LayoutOrder      = #W._tabs + 1,
            Parent           = Sidebar,
        })
        Corner(TBtn, 6)

        -- Active indicator bar
        local TInd = New("Frame", {
            Size             = UDim2.new(0, 2, 0.55, 0),
            Position         = UDim2.new(0, 0, 0.225, 0),
            BackgroundColor3 = T.Accent,
            BorderSizePixel  = 0,
            ZIndex           = 5,
            Visible          = false,
            Parent           = TBtn,
        })
        Corner(TInd, 2)

        -- Icon placeholder (left dot)
        local TDot = New("Frame", {
            Size             = UDim2.new(0, 5, 0, 5),
            Position         = UDim2.new(0, 11, 0.5, -2),
            BackgroundColor3 = T.TextLow,
            BorderSizePixel  = 0,
            ZIndex           = 5,
            Parent           = TBtn,
        })
        Corner(TDot, 4)

        New("TextLabel", {
            Size             = UDim2.new(1, -26, 1, 0),
            Position         = UDim2.new(0, 24, 0, 0),
            BackgroundTransparency = 1,
            Text             = tabName,
            TextColor3       = T.TextLow,
            Font             = Enum.Font.GothamSemibold,
            TextSize         = 12,
            TextXAlignment   = Enum.TextXAlignment.Left,
            ZIndex           = 5,
            Parent           = TBtn,
        })

        -- ── Scrollable content pane ─────────
        local Pane = New("ScrollingFrame", {
            Name                = "Pane_" .. tabName,
            Size                = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            BorderSizePixel     = 0,
            ScrollBarThickness  = 2,
            ScrollBarImageColor3 = T.Border,
            CanvasSize          = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            Visible             = false,
            ZIndex              = 3,
            Parent              = Content,
        })
        Padding(Pane, 10, 14, 10, 10)
        ListLayout(Pane, Enum.FillDirection.Vertical, 8)

        Tab._btn  = TBtn
        Tab._ind  = TInd
        Tab._dot  = TDot
        Tab._pane = Pane

        -- ── Activation logic ────────────────
        local function Activate()
            for _, t in ipairs(W._tabs) do
                t._active = false
                Tween(t._btn,  TI.Fast, { BackgroundColor3 = T.Surface })
                Tween(t._dot,  TI.Fast, { BackgroundColor3 = T.TextLow })
                -- Text color via child label
                for _, ch in ipairs(t._btn:GetChildren()) do
                    if ch:IsA("TextLabel") then
                        Tween(ch, TI.Fast, { TextColor3 = T.TextLow })
                    end
                end
                t._ind.Visible  = false
                t._pane.Visible = false
            end
            Tab._active        = true
            Tween(TBtn, TI.Fast, { BackgroundColor3 = T.Panel })
            Tween(TDot, TI.Fast, { BackgroundColor3 = T.AccentGlow })
            for _, ch in ipairs(TBtn:GetChildren()) do
                if ch:IsA("TextLabel") then
                    Tween(ch, TI.Fast, { TextColor3 = T.TextHi })
                end
            end
            TInd.Visible    = true
            Pane.Visible    = true
            W._activeTab    = Tab
        end

        TBtn.MouseButton1Click:Connect(Activate)
        TBtn.MouseEnter:Connect(function()
            if not Tab._active then
                Tween(TBtn, TI.Fast, { BackgroundColor3 = T.Hover })
            end
        end)
        TBtn.MouseLeave:Connect(function()
            if not Tab._active then
                Tween(TBtn, TI.Fast, { BackgroundColor3 = T.Surface })
            end
        end)

        table.insert(W._tabs, Tab)
        if #W._tabs == 1 then Activate() end

