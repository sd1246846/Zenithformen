    Sidebar.Position = UDim2.new(0, 0, 0, 40)
    Sidebar.BackgroundColor3 = Library.Charcoal
    Sidebar.Parent = Main
    local tl = Instance.new("UIListLayout", Sidebar)

    MakeDraggable(Main, TopBar)

    local Window = { CurrentTab = nil }

    function Window:AddTab(name)
        local TabBtn = Instance.new("TextButton")
        TabBtn.Size = UDim2.new(1, 0, 0, 35)
        TabBtn.BackgroundTransparency = 1
        TabBtn.Text = name
        TabBtn.TextColor3 = Library.TextDark
        TabBtn.Font = Enum.Font.Gotham
        TabBtn.Parent = Sidebar

        local TabFrame = Instance.new("ScrollingFrame")
        TabFrame.Size = UDim2.new(1, 0, 1, 0)
        TabFrame.BackgroundTransparency = 1
        TabFrame.Visible = false
        TabFrame.ScrollBarThickness = 2
        TabFrame.Parent = Container
        local tfl = Instance.new("UIListLayout", TabFrame)
        tfl.Padding = UDim.new(0, 10)

        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Container:GetChildren()) do v.Visible = false end
            for _, v in pairs(Sidebar:GetChildren()) do if v:IsA("TextButton") then v.TextColor3 = Library.TextDark end end
            TabFrame.Visible = true
            TabBtn.TextColor3 = Library.Text
        end)

        if not Window.CurrentTab then
            Window.CurrentTab = TabFrame
            TabFrame.Visible = true
            TabBtn.TextColor3 = Library.Text
        end

        local Tab = {}
        function Tab:AddSection(sname)
            local SectionFrame = Instance.new("Frame")
            SectionFrame.Size = UDim2.new(1, -10, 0, 30)
            SectionFrame.BackgroundTransparency = 1
            SectionFrame.Parent = TabFrame
            local sl = Instance.new("UIListLayout", SectionFrame)
            sl.Padding = UDim.new(0, 5)

            local function UpdateSize()
                SectionFrame.Size = UDim2.new(1, -10, 0, sl.AbsoluteContentSize.Y + 5)
                TabFrame.CanvasSize = UDim2.new(0, 0, 0, tfl.AbsoluteContentSize.Y + 10)
            end
            sl:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdateSize)

            local Section = {}
            function Section:AddButton(text, callback)
                local b = Instance.new("TextButton")
                b.Size = UDim2.new(1, 0, 0, 30)
                b.BackgroundColor3 = Library.Charcoal
                b.Text = text
                b.TextColor3 = Library.Text
                b.Font = Enum.Font.Gotham
                b.Parent = SectionFrame
                Instance.new("UICorner", b)
                Instance.new("UIStroke", b).Color = Library.Gray
                b.MouseButton1Click:Connect(callback)
            end

            function Section:AddToggle(text, default, callback)
                local b = Instance.new("TextButton")
                b.Size = UDim2.new(1, 0, 0, 30)
                b.BackgroundColor3 = Library.Charcoal
                b.Text = ""
                b.Parent = SectionFrame
                Instance.new("UICorner", b)
                local s = Instance.new("UIStroke", b) s.Color = Library.Gray
                
                local lbl = Instance.new("TextLabel")
                lbl.Size = UDim2.new(1, -40, 1, 0)
                lbl.Position = UDim2.new(0, 10, 0, 0)
                lbl.Text = text
                lbl.TextColor3 = Library.Text
                lbl.BackgroundTransparency = 1
                lbl.TextXAlignment = Enum.TextXAlignment.Left
                lbl.Font = Enum.Font.Gotham
                lbl.Parent = b

                local box = Instance.new("Frame")
                box.Size = UDim2.new(0, 16, 0, 16)
                box.Position = UDim2.new(1, -26, 0.5, -8)
                box.BackgroundColor3 = default and Library.Accent or Library.Black
                box.Parent = b
                Instance.new("UICorner", box)
                
                local state = default
                b.MouseButton1Click:Connect(function()
                    state = not state
                    box.BackgroundColor3 = state and Library.Accent or Library.Black
                    callback(state)
                end)
            end

            function Section:AddSlider(text, min, max, default, callback)
                local s = Instance.new("Frame")
                s.Size = UDim2.new(1, 0, 0, 45)
                s.BackgroundTransparency = 1
                s.Parent = SectionFrame
                
                local l = Instance.new("TextLabel")
                l.Size = UDim2.new(1, 0, 0, 20)
                l.Text = text .. ": " .. default
                l.TextColor3 = Library.Text
                l.BackgroundTransparency = 1
                l.TextXAlignment = Enum.TextXAlignment.Left
                l.Font = Enum.Font.Gotham
                l.Parent = s

                local bar = Instance.new("TextButton")
                bar.Size = UDim2.new(1, 0, 0, 6)
                bar.Position = UDim2.new(0, 0, 0, 30)
                bar.BackgroundColor3 = Library.Gray
                bar.Text = ""
                bar.Parent = s
                Instance.new("UICorner", bar)

                local fill = Instance.new("Frame")
                fill.Size = UDim2.new((default-min)/(max-min), 0, 1, 0)
                fill.BackgroundColor3 = Library.Accent
                fill.Parent = bar
                Instance.new("UICorner", fill)

                local sliding = false
                local function move()
                    local mousePos = UIS:GetMouseLocation().X
                    local barPos = bar.AbsolutePosition.X
                    local barSize = bar.AbsoluteSize.X
                    local percent = math.clamp((mousePos - barPos) / barSize, 0, 1)
                    local value = math.floor(min + (max - min) * percent)
                    fill.Size = UDim2.new(percent, 0, 1, 0)
                    l.Text = text .. ": " .. value
                    callback(value)
                end

                bar.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then sliding = true move() end end)
                UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end end)
                UIS.InputChanged:Connect(function(input) if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then move() end end)
            end

            function Section:AddDropdown(text, list, callback)
                local d = Instance.new("Frame")
                d.Size = UDim2.new(1, 0, 0, 35)
                d.BackgroundColor3 = Library.Charcoal
                d.ClipsDescendants = true
                d.Parent = SectionFrame
                Instance.new("UICorner", d)
                local ds = Instance.new("UIStroke", d) ds.Color = Library.Gray

                local h = Instance.new("TextButton")
                h.Size = UDim2.new(1, 0, 0, 35)
                h.BackgroundTransparency = 1
                h.Text = text .. " [v]"
                h.TextColor3 = Library.Text
                h.Font = Enum.Font.Gotham
                h.Parent = d

                local o = Instance.new("Frame")
                o.Size = UDim2.new(1, 0, 0, 0)
                o.Position = UDim2.new(0, 0, 0, 35)
                o.BackgroundTransparency = 1
                o.Parent = d
                local ol = Instance.new("UIListLayout", o)

                local open = false
                local function toggle(forceClose)
                    if forceClose then open = false else open = not open end
                    RunService.Heartbeat:Wait()
                    local target = open and (35 + ol.AbsoluteContentSize.Y + 5) or 35
                    Tween(d, 0.2, {Size = UDim2.new(1, 0, 0, target)})
                    task.delay(0.2, UpdateSize)
                end
                
                h.MouseButton1Click:Connect(function() toggle() end)

                local dropFuncs = {}
                function dropFuncs:Set(val)
                    h.Text = text .. " [" .. tostring(val) .. "]"
                    pcall(callback, val)
                end

                for _, v in pairs(list) do
                    local opt = Instance.new("TextButton")
                    opt.Size = UDim2.new(1, 0, 0, 25)
                    opt.BackgroundTransparency = 1
                    opt.Text = v
                    opt.TextColor3 = Library.TextDark
                    opt.Font = Enum.Font.Gotham
                    opt.Parent = o
                    opt.MouseButton1Click:Connect(function()
                        dropFuncs:Set(v)
                        toggle(true)
                    end)
                end
                
                return dropFuncs
            end

            function Section:AddKeybind(text, default, callback)
                local b = Instance.new("TextButton")
                b.Size = UDim2.new(1, 0, 0, 30)
                b.BackgroundColor3 = Library.Charcoal
                b.Text = ""
                b.Parent = SectionFrame
                Instance.new("UICorner", b)
                Instance.new("UIStroke", b).Color = Library.Gray
                
                local lbl = Instance.new("TextLabel")
                lbl.Size = UDim2.new(1, -80, 1, 0)
                lbl.Position = UDim2.new(0, 10, 0, 0)
                lbl.Text = text
                lbl.TextColor3 = Library.Text
                lbl.BackgroundTransparency = 1
                lbl.TextXAlignment = Enum.TextXAlignment.Left
                lbl.Font = Enum.Font.Gotham
                lbl.Parent = b

                local bindLbl = Instance.new("TextLabel")
                bindLbl.Size = UDim2.new(0, 70, 0, 20)
                bindLbl.Position = UDim2.new(1, -75, 0.5, -10)
                bindLbl.BackgroundColor3 = Library.Gray
                bindLbl.Text = default.Name
                bindLbl.TextColor3 = Library.Text
                bindLbl.Font = Enum.Font.GothamBold
                bindLbl.Parent = b
                Instance.new("UICorner", bindLbl)

                local current = default
                local binding = false

                b.MouseButton1Click:Connect(function() binding = true bindLbl.Text = "..." end)
                UIS.InputBegan:Connect(function(i, g)
                    if binding then
                        if i.KeyCode ~= Enum.KeyCode.Unknown then
                            current = i.KeyCode
                            bindLbl.Text = current.Name
                            binding = false
                        end
                    elseif not g and i.KeyCode == current then
                        callback()
                    end
                end)
            end

            function Section:AddLabel(text)
                local l = Instance.new("TextLabel")
                l.Size = UDim2.new(1, 0, 0, 20)
                l.Text = text
                l.TextColor3 = Library.TextDark
                l.BackgroundTransparency = 1
                l.Font = Enum.Font.Gotham
                l.TextXAlignment = Enum.TextXAlignment.Left
                l.Parent = SectionFrame
                UpdateSize()
            end

            return Section
        end
        return Tab
    end
    return Window
end

return Library
