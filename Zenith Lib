    ConfirmBox.Position = UDim2.new(0.5, -130, 0.5, -60)
    ConfirmBox.BackgroundColor3 = Library.Charcoal
    ConfirmBox.Parent = ExitConfirm
    Instance.new("UICorner", ConfirmBox)
    local cs = Instance.new("UIStroke", ConfirmBox)
    cs.Color = Library.Gray

    local ConfirmTitle = Instance.new("TextLabel")
    ConfirmTitle.Size = UDim2.new(1, 0, 0, 40)
    ConfirmTitle.BackgroundTransparency = 1
    ConfirmTitle.Text = "ARE YOU SURE?"
    ConfirmTitle.TextColor3 = Library.Text
    ConfirmTitle.Font = Enum.Font.GothamBold
    ConfirmTitle.Parent = ConfirmBox

    local YesBtn = Instance.new("TextButton")
    YesBtn.Size = UDim2.new(0.4, 0, 0, 30)
    YesBtn.Position = UDim2.new(0.08, 0, 0.6, 0)
    YesBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
    YesBtn.Text = "YES"
    YesBtn.TextColor3 = Library.Text
    YesBtn.Font = Enum.Font.GothamBold
    YesBtn.Parent = ConfirmBox
    Instance.new("UICorner", YesBtn)

    local NoBtn = Instance.new("TextButton")
    NoBtn.Size = UDim2.new(0.4, 0, 0, 30)
    NoBtn.Position = UDim2.new(0.52, 0, 0.6, 0)
    NoBtn.BackgroundColor3 = Library.Gray
    NoBtn.Text = "NO"
    NoBtn.TextColor3 = Library.Text
    NoBtn.Font = Enum.Font.GothamBold
    NoBtn.Parent = ConfirmBox
    Instance.new("UICorner", NoBtn)

    Close.MouseButton1Click:Connect(function()
        ExitConfirm.Visible = true
        Tween(ExitConfirm, 0.3, {BackgroundTransparency = 0.2})
    end)
    NoBtn.MouseButton1Click:Connect(function()
        Tween(ExitConfirm, 0.2, {BackgroundTransparency = 1})
        task.wait(0.2)
        ExitConfirm.Visible = false
    end)
    YesBtn.MouseButton1Click:Connect(function() SteelUI:Destroy() end)

    local Container = Instance.new("Frame")
    Container.Size = UDim2.new(1, -170, 1, -50)
    Container.Position = UDim2.new(0, 170, 0, 50)
    Container.BackgroundTransparency = 1
    Container.Parent = Main

    local TabList = Instance.new("Frame")
    TabList.Size = UDim2.new(0, 160, 1, -40)
    TabList.Position = UDim2.new(0, 0, 0, 40)
    TabList.BackgroundColor3 = Library.Charcoal
    TabList.Parent = Main
    local tl = Instance.new("UIListLayout", TabList)

    MakeDraggable(Main, TopBar)

    local Window = { CurrentTab = nil }

    function Window:AddTab(name)
        local TabBtn = Instance.new("TextButton")
        TabBtn.Size = UDim2.new(1, 0, 0, 35)
        TabBtn.BackgroundTransparency = 1
        TabBtn.Text = name
        TabBtn.TextColor3 = Library.TextDark
        TabBtn.Font = Enum.Font.Gotham
        TabBtn.Parent = TabList

        local TabFrame = Instance.new("ScrollingFrame")
        TabFrame.Size = UDim2.new(1, 0, 1, 0)
        TabFrame.BackgroundTransparency = 1
        TabFrame.Visible = false
        TabFrame.ScrollBarThickness = 2
        TabFrame.Parent = Container
        local tfl = Instance.new("UIListLayout", TabFrame)
        tfl.Padding = UDim.new(0, 10)

        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Container:GetChildren()) do v.Visible = false end
            TabFrame.Visible = true
        end)

        local Tab = {}
        function Tab:AddSection(sname)
            local SectionFrame = Instance.new("Frame")
            SectionFrame.Size = UDim2.new(1, 0, 0, 30)
            SectionFrame.BackgroundTransparency = 1
            SectionFrame.Parent = TabFrame
            local sl = Instance.new("UIListLayout", SectionFrame)
            sl.Padding = UDim.new(0, 5)

            local function UpdateSize()
                SectionFrame.Size = UDim2.new(1, 0, 0, sl.AbsoluteContentSize.Y + 5)
                TabFrame.CanvasSize = UDim2.new(0, 0, 0, tfl.AbsoluteContentSize.Y)
            end
            sl:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdateSize)

            local Section = {}
            function Section:AddButton(text, callback)
                local b = Instance.new("TextButton")
                b.Size = UDim2.new(1, -10, 0, 30)
                b.BackgroundColor3 = Library.Gray
                b.Text = text
                b.TextColor3 = Library.Text
                b.Font = Enum.Font.Gotham
                b.Parent = SectionFrame
                Instance.new("UICorner", b)
                b.MouseButton1Click:Connect(callback)
            end

            function Section:AddToggle(text, default, callback)
                local b = Instance.new("TextButton")
                b.Size = UDim2.new(1, -10, 0, 30)
                b.BackgroundColor3 = Library.Gray
                b.Text = text
                b.TextColor3 = default and Library.Accent or Library.Text
                b.Font = Enum.Font.Gotham
                b.Parent = SectionFrame
                Instance.new("UICorner", b)
                local state = default
                b.MouseButton1Click:Connect(function()
                    state = not state
                    b.TextColor3 = state and Library.Accent or Library.Text
                    callback(state)
                end)
            end

            function Section:AddSlider(text, min, max, default, callback)
                local s = Instance.new("Frame")
                s.Size = UDim2.new(1, -10, 0, 40)
                s.BackgroundTransparency = 1
                s.Parent = SectionFrame
                local l = Instance.new("TextLabel")
                l.Size = UDim2.new(1, 0, 0, 20)
                l.Text = text .. ": " .. default
                l.TextColor3 = Library.Text
                l.BackgroundTransparency = 1
                l.Parent = s
            end

            function Section:AddDropdown(text, list, callback)
                local d = Instance.new("Frame")
                d.Size = UDim2.new(1, -10, 0, 35)
                d.BackgroundColor3 = Library.Gray
                d.ClipsDescendants = true
                d.Parent = SectionFrame
                Instance.new("UICorner", d)

                local h = Instance.new("TextButton")
                h.Size = UDim2.new(1, 0, 0, 35)
                h.BackgroundTransparency = 1
                h.Text = text .. " [v]"
                h.TextColor3 = Library.Text
                h.Font = Enum.Font.Gotham
                h.Parent = d

                local o = Instance.new("Frame")
                o.Size = UDim2.new(1, 0, 0, 0)
                o.Position = UDim2.new(0, 0, 0, 35)
                o.BackgroundTransparency = 1
                o.Parent = d
                local ol = Instance.new("UIListLayout", o)

                local open = false
                local function toggle(forceClose)
                    if forceClose then open = false else open = not open end
                    local target = open and (35 + ol.AbsoluteContentSize.Y + 5) or 35
                    Tween(d, 0.2, {Size = UDim2.new(1, -10, 0, target)})
                    task.wait(0.25)
                    UpdateSize()
                end
                
                h.MouseButton1Click:Connect(function() toggle() end)

                local dropFuncs = {}
                
                function dropFuncs:Set(val)
                    h.Text = text .. " [" .. tostring(val) .. "]"
                    pcall(callback, val)
                end

                for _, v in pairs(list) do
                    local opt = Instance.new("TextButton")
                    opt.Size = UDim2.new(1, 0, 0, 25)
                    opt.BackgroundTransparency = 1
                    opt.Text = v
                    opt.TextColor3 = Library.TextDark
                    opt.Font = Enum.Font.Gotham
                    opt.Parent = o
                    opt.MouseButton1Click:Connect(function()
                        dropFuncs:Set(v)
                        toggle(true)
                    end)
                end
                
                return dropFuncs
            end

            return Section
        end
        return Tab
    end
    return Window
end

return Library
