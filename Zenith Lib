            function Section:AddSlider(text, min, max, default, callback)
                local Slider = Instance.new("Frame")
                local STitle = Instance.new("TextLabel")
                local SVal = Instance.new("TextLabel")
                local SBar = Instance.new("TextButton")
                local SFill = Instance.new("Frame")

                Slider.Size = UDim2.new(1, 0, 0, 48)
                Slider.BackgroundTransparency = 1
                Slider.Parent = SectionFrame

                STitle.Size = UDim2.new(1, 0, 0, 22)
                STitle.BackgroundTransparency = 1
                STitle.Text = text
                STitle.TextColor3 = Library.Text
                STitle.Font = Enum.Font.Gotham
                STitle.TextSize = 13
                STitle.TextXAlignment = Enum.TextXAlignment.Left
                STitle.Parent = Slider

                SVal.Size = UDim2.new(1, 0, 0, 22)
                SVal.BackgroundTransparency = 1
                SVal.Text = tostring(default)
                SVal.TextColor3 = Library.TextDark
                SVal.Font = Enum.Font.Gotham
                SVal.TextSize = 12
                SVal.TextXAlignment = Enum.TextXAlignment.Right
                SVal.Parent = Slider

                SBar.Size = UDim2.new(1, 0, 0, 6)
                SBar.Position = UDim2.new(0, 0, 0, 32)
                SBar.BackgroundColor3 = Library.Charcoal
                SBar.AutoButtonColor = false
                SBar.Text = ""
                SBar.Parent = Slider
                Instance.new("UICorner", SBar)

                SFill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
                SFill.BackgroundColor3 = Library.Accent
                SFill.BorderSizePixel = 0
                SFill.Parent = SBar
                Instance.new("UICorner", SFill)

                local sliding = false
                local function move()
                    local mousePos = UIS:GetMouseLocation().X
                    local barPos = SBar.AbsolutePosition.X
                    local barSize = SBar.AbsoluteSize.X
                    local perc = math.clamp((mousePos - barPos) / barSize, 0, 1)
                    local val = math.floor(min + (max - min) * perc)
                    
                    SFill.Size = UDim2.new(perc, 0, 1, 0)
                    SVal.Text = tostring(val)
                    pcall(callback, val)
                end

                SBar.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = true
                    end
                end)
                UIS.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = false
                    end
                end)
                UIS.InputChanged:Connect(function(input)
                    if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
                        move()
                    end
                end)
            end

            function Section:AddDropdown(text, list, callback)
                local Dropdown = Instance.new("Frame")
                local DBtn = Instance.new("TextButton")
                local DTitle = Instance.new("TextLabel")
                local DVal = Instance.new("TextLabel")
                local DList = Instance.new("Frame")
                local DLay = Instance.new("UIListLayout")

                Dropdown.Size = UDim2.new(1, 0, 0, 32)
                Dropdown.BackgroundColor3 = Library.Charcoal
                Dropdown.ClipsDescendants = true
                Dropdown.Parent = SectionFrame
                Instance.new("UICorner", Dropdown).CornerRadius = UDim.new(0, 5)
                local ds = Instance.new("UIStroke", Dropdown)
                ds.Color = Library.Gray
                ds.Thickness = 1

                DBtn.Size = UDim2.new(1, 0, 0, 32)
                DBtn.BackgroundTransparency = 1
                DBtn.Text = ""
                DBtn.Parent = Dropdown

                DTitle.Size = UDim2.new(0, 120, 1, 0)
                DTitle.Position = UDim2.new(0, 12, 0, 0)
                DTitle.BackgroundTransparency = 1
                DTitle.Text = text
                DTitle.TextColor3 = Library.Text
                DTitle.Font = Enum.Font.Gotham
                DTitle.TextSize = 13
                DTitle.TextXAlignment = Enum.TextXAlignment.Left
                DTitle.Parent = Dropdown

                DVal.Size = UDim2.new(1, -25, 1, 0)
                DVal.BackgroundTransparency = 1
                DVal.Text = "..."
                DVal.TextColor3 = Library.TextDark
                DVal.Font = Enum.Font.Gotham
                DVal.TextSize = 12
                DVal.TextXAlignment = Enum.TextXAlignment.Right
                DVal.Parent = Dropdown

                DList.Size = UDim2.new(1, 0, 0, 0)
                DList.Position = UDim2.new(0, 0, 0, 32)
                DList.BackgroundTransparency = 1
                DList.Parent = Dropdown

                DLay.Parent = DList
                DLay.SortOrder = Enum.SortOrder.LayoutOrder

                local open = false
                DBtn.MouseButton1Click:Connect(function()
                    open = not open
                    local targetY = open and (32 + DLay.AbsoluteContentSize.Y + 5) or 32
                    Tween(Dropdown, 0.3, {Size = UDim2.new(1, 0, 0, targetY)})
                end)

                for _, v in pairs(list) do
                    local Opt = Instance.new("TextButton")
                    Opt.Size = UDim2.new(1, 0, 0, 28)
                    Opt.BackgroundTransparency = 1
                    Opt.Text = v
                    Opt.TextColor3 = Library.TextDark
                    Opt.Font = Enum.Font.Gotham
                    Opt.TextSize = 12
                    Opt.Parent = DList

                    Opt.MouseButton1Click:Connect(function()
                        DVal.Text = v
                        open = false
                        Tween(Dropdown, 0.2, {Size = UDim2.new(1, 0, 0, 32)})
                        pcall(callback, v)
                    end)
                    Opt.MouseEnter:Connect(function() Opt.TextColor3 = Library.Text end)
                    Opt.MouseLeave:Connect(function() Opt.TextColor3 = Library.TextDark end)
                end
                
                Dropdown.MouseEnter:Connect(function() Tween(ds, 0.2, {Color = Library.LightGray}) end)
                Dropdown.MouseLeave:Connect(function() Tween(ds, 0.2, {Color = Library.Gray}) end)
            end

            function Section:AddKeybind(text, default, callback)
                local Keybind = Instance.new("Frame")
                local KTitle = Instance.new("TextLabel")
                local KBtn = Instance.new("TextButton")

                Keybind.Size = UDim2.new(1, 0, 0, 32)
                Keybind.BackgroundColor3 = Library.Charcoal
                Keybind.Parent = SectionFrame
                Instance.new("UICorner", Keybind).CornerRadius = UDim.new(0, 5)
                local ks = Instance.new("UIStroke", Keybind)
                ks.Color = Library.Gray
                ks.Thickness = 1

                KTitle.Size = UDim2.new(0, 120, 1, 0)
                KTitle.Position = UDim2.new(0, 12, 0, 0)
                KTitle.BackgroundTransparency = 1
                KTitle.Text = text
                KTitle.TextColor3 = Library.Text
                KTitle.Font = Enum.Font.Gotham
                KTitle.TextSize = 13
                KTitle.TextXAlignment = Enum.TextXAlignment.Left
                KTitle.Parent = Keybind

                KBtn.Size = UDim2.new(0, 70, 0, 22)
                KBtn.Position = UDim2.new(1, -82, 0.5, -11)
                KBtn.BackgroundColor3 = Library.Gray
                KBtn.Text = default.Name
                KBtn.TextColor3 = Library.Text
                KBtn.Font = Enum.Font.GothamBold
                KBtn.TextSize = 11
                KBtn.Parent = Keybind
                Instance.new("UICorner", KBtn).CornerRadius = UDim.new(0, 4)

                local current = default
                local binding = false

                KBtn.MouseButton1Click:Connect(function()
                    binding = true
                    KBtn.Text = "..."
                end)

                UIS.InputBegan:Connect(function(input, gpe)
                    if binding and input.UserInputType == Enum.UserInputType.Keyboard then
                        binding = false
                        current = input.KeyCode
                        KBtn.Text = current.Name
                    elseif not gpe and not binding and input.KeyCode == current then
                        pcall(callback)
                    end
                end)
            end

            function Section:AddLabel(text)
                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, 0, 0, 20)
                Label.BackgroundTransparency = 1
                Label.Text = text
                Label.TextColor3 = Library.TextDark
                Label.Font = Enum.Font.Gotham
                Label.TextSize = 12
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = SectionFrame
                UpdateSize()
            end

            return Section
        end

        return Tab
    end

    return Window
end

return Library
