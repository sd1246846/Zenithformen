    local function Minimize()
        if W._minimized or W._destroyed then return end
        W._minimized  = true
        _drag         = false
        local tgt = UDim2.new(Main.Position.X.Scale, Main.Position.X.Offset,
                              Main.Position.Y.Scale, Main.Position.Y.Offset)
        Tween(Main,   TI.Med,  { Size = UDim2.new(0, 690, 0, 44) })
        Tween(Shadow, TI.Med,  { Size = UDim2.new(0, 710, 0, 64), BackgroundTransparency = 0.85 })
        task.delay(0.25, function()
            if W._minimized then
                Main.Visible    = false
                Shadow.Visible  = false
                ReopenBtn.Visible = true
                Main.Size       = UDim2.new(0, 690, 0, 490)
                Shadow.Size     = UDim2.new(0, 710, 0, 510)
                Shadow.BackgroundTransparency = 0.60
            end
        end)
